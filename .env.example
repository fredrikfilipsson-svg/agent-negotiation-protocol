# Copy to .env.local for local development. Neither variable is a secret.

# Canonical origin of this site, used for metadata and OpenGraph URLs.
NEXT_PUBLIC_SITE_URL=https://anp.dev

# Default buyer host base URL for the playground. The playground calls this
# host directly from the visitor's browser, so the host must allow this
# site's origin in its CORS policy.
NEXT_PUBLIC_DEFAULT_BUYER_HOST=https://app.vendorbenchmark.com
